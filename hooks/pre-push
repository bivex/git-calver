#!/usr/bin/env bash
# git-version pre-push hook
# Validates that version exists before push

# Find git-version command
GIT_VERSION_CMD=""
if command -v git-version >/dev/null 2>&1; then
    GIT_VERSION_CMD="git-version"
elif [ -f "$HOME/.local/bin/git-version" ]; then
    GIT_VERSION_CMD="$HOME/.local/bin/git-version"
elif [ -f "/usr/local/bin/git-version" ]; then
    GIT_VERSION_CMD="/usr/local/bin/git-version"
fi

# If git-version is not found, skip validation
if [ -z "$GIT_VERSION_CMD" ]; then
    exit 0
fi

# Check VERSION.txt exists
VERSION_FILE="VERSION.txt"
if [ ! -f "$VERSION_FILE" ]; then
    echo "Warning: $VERSION_FILE not found. Run 'git-version init' to initialize."
    read -p "Continue pushing? (y/N) " -n 1 -r
    echo
    if [[ ! $REPLY =~ ^[Yy]$ ]]; then
        echo "Push cancelled."
        exit 1
    fi
    exit 0
fi

# Get version from file (strip color codes and 'v' prefix)
FILE_VERSION=$(cat "$VERSION_FILE" | tr -d '\033' | sed 's/\[[0-9;]*m//g' | sed 's/^v//')

# Validate version format (YYYY.MM.DD or YYYY.MM.DD-N)
if ! [[ "$FILE_VERSION" =~ ^[0-9]{4}\.[0-9]{2}\.[0-9]{2}(-[0-9]+)?$ ]]; then
    echo "Error: Invalid version format in $VERSION_FILE: $FILE_VERSION"
    echo "Expected format: YYYY.MM.DD or YYYY.MM.DD-N"
    read -p "Push anyway? (y/N) " -n 1 -r
    echo
    if [[ ! $REPLY =~ ^[Yy]$ ]]; then
        echo "Push cancelled."
        exit 1
    fi
    exit 0
fi

# Check if tag exists
TAG_VERSION="v${FILE_VERSION}"

# Check if tag exists locally
if ! git rev-parse -q --verify "refs/tags/${TAG_VERSION}" >/dev/null 2>&1; then
    echo "Warning: Tag $TAG_VERSION does not exist"
    echo "Run 'git-version bump' to create the tag"
    read -p "Push anyway? (y/N) " -n 1 -r
    echo
    if [[ ! $REPLY =~ ^[Yy]$ ]]; then
        echo "Push cancelled. Create version tag with: git-version bump"
        exit 1
    fi
fi

# Check for uncommitted changes in VERSION.txt
if ! git diff --quiet "$VERSION_FILE" 2>/dev/null; then
    echo "Warning: $VERSION_FILE has uncommitted changes"
    read -p "Continue pushing? (y/N) " -n 1 -r
    echo
    if [[ ! $REPLY =~ ^[Yy]$ ]]; then
        echo "Push cancelled. Commit changes first or use git stash"
        exit 1
    fi
fi

exit 0
