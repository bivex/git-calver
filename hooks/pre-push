#!/usr/bin/env bash
# git-version pre-push hook
# Validates that version exists before push

# Get the directory where this script is located
HOOK_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(dirname "$HOOK_DIR")"

# Source libraries
# shellcheck source=../lib/utils.sh
source "${PROJECT_ROOT}/lib/utils.sh"
# shellcheck source=../lib/core.sh
source "${PROJECT_ROOT}/lib/core.sh"

# Get current branch
CURRENT_BRANCH=$(git symbolic-ref -q --short HEAD)

if [ -z "$CURRENT_BRANCH" ]; then
    log_warn "Not on a branch, skipping version check"
    exit 0
fi

# Check if VERSION.txt exists
VERSION_FILE="${VERSION_FILE:-VERSION.txt}"

if [ ! -f "$VERSION_FILE" ]; then
    log_warn "No $VERSION_FILE found. Run 'git-version init' to initialize."
    read -p "Continue without version check? (y/N) " -n 1 -r
    echo
    if [[ ! $REPLY =~ ^[Yy]$ ]]; then
        exit 1
    fi
    exit 0
fi

# Get version from file
FILE_VERSION=$(cat "$VERSION_FILE")

# Validate version format
if ! is_valid_version "$FILE_VERSION"; then
    log_error "Invalid version format in $VERSION_FILE: $FILE_VERSION"
    log_error "Expected format: YYYY.MM.DD or YYYY.MM.DD-N"
    exit 1
fi

# Check if tag exists
TAG_VERSION=$(normalize_version "$FILE_VERSION")

if ! tag_exists "$TAG_VERSION"; then
    log_warn "Tag $TAG_VERSION does not exist for version $FILE_VERSION"
    log_warn "Run 'git-version bump' to create the tag"
    read -p "Push anyway? (y/N) " -n 1 -r
    echo
    if [[ ! $REPLY =~ ^[Yy]$ ]]; then
        log_info "Push cancelled. Create version tag with: git-version bump"
        exit 1
    fi
fi

# Check for uncommitted changes in VERSION.txt
if ! git diff --quiet "$VERSION_FILE" 2>/dev/null; then
    log_warn "$VERSION_FILE has uncommitted changes"
    read -p "Continue pushing? (y/N) " -n 1 -r
    echo
    if [[ ! $REPLY =~ ^[Yy]$ ]]; then
        log_info "Push cancelled. Commit changes first or use git stash"
        exit 1
    fi
fi

exit 0
