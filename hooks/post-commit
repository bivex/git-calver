#!/usr/bin/env bash
# git-version post-commit hook
# Automatically updates version after every commit

# Configuration
AUTO_BUMP=${AUTO_BUMP:-true}

# Skip if auto-bump is disabled
if [ "$AUTO_BUMP" != "true" ]; then
    exit 0
fi

# Get the last commit message
LAST_COMMIT=$(git log -1 --pretty=format:"%s")

# Skip commits that start with "chore: release" (release commits)
if [[ "$LAST_COMMIT" =~ ^chore:\ release ]]; then
    exit 0
fi

# Find git-version command
GIT_VERSION_CMD=""
if command -v git-version >/dev/null 2>&1; then
    GIT_VERSION_CMD="git-version"
elif [ -f "$HOME/.local/bin/git-version" ]; then
    GIT_VERSION_CMD="$HOME/.local/bin/git-version"
elif [ -f "/usr/local/bin/git-version" ]; then
    GIT_VERSION_CMD="/usr/local/bin/git-version"
fi

if [ -z "$GIT_VERSION_CMD" ]; then
    exit 0
fi

# Get current and next version (without color codes)
CURRENT_VERSION=$($GIT_VERSION_CMD -q current 2>/dev/null || echo "")
NEXT_VERSION=$($GIT_VERSION_CMD -q next 2>/dev/null | head -1 | tr -d '\033' | sed 's/\[[0-9;]*m//g' || echo "")

# Strip any remaining ANSI codes
NEXT_VERSION=$(echo "$NEXT_VERSION" | sed 's/\[[0-9;]*m//g' | tr -d '[:cntrl:]')

# Only update if version changed and both are valid
if [ -n "$NEXT_VERSION" ] && [ -n "$CURRENT_VERSION" ] && [ "$NEXT_VERSION" != "$CURRENT_VERSION" ]; then
    # Update VERSION.txt (strip 'v' prefix)
    echo "${NEXT_VERSION}" > VERSION.txt

    # Update CHANGELOG.md
    $GIT_VERSION_CMD changelog > /tmp/git-version-changelog.$$ 2>/dev/null || true
    if [ -s /tmp/git-version-changelog.$$ ]; then
        # Preserve header and prepend new entry
        if [ -f CHANGELOG.md ]; then
            head -n 3 CHANGELOG.md > /tmp/git-version-new.$$
            tail -n +4 /tmp/git-version-changelog.$$ >> /tmp/git-version-new.$$
            mv /tmp/git-version-new.$$ CHANGELOG.md
        else
            mv /tmp/git-version-changelog.$$ CHANGELOG.md
        fi
    fi
    rm -f /tmp/git-version-changelog.$$

    # Stage files for the next commit
    git add VERSION.txt CHANGELOG.md 2>/dev/null || true
fi

exit 0
