{
  "permissions": {
    "allow": [
      "Bash(git --version)",
      "WebSearch",
      "Bash(chmod +x bin/git-version install.sh hooks/post-commit hooks/pre-push)",
      "Bash(chmod +x lib/*.sh)",
      "Bash(./install.sh)",
      "Bash(git init:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(~/.local/bin/git-version init:*)",
      "Bash(./install.sh --uninstall)",
      "Bash(~/.local/bin/git-version next:*)",
      "Bash(~/.local/bin/git-version bump:*)",
      "Bash(chmod +x hooks/post-commit)",
      "Bash(~/.local/bin/git-version hooks:*)",
      "Bash(bash .git/hooks/post-commit)",
      "Bash(bash -x .git/hooks/post-commit)",
      "Bash(chmod +x hooks/pre-push)"
    ]
  }
}
